{% extends "layouts/layout.njk" %}

{% set noAccountMenuOrFooter = true %}

{% block content %}
	<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <h1 class="govuk-heading-l">Check your answers</h1>
        <dl class="govuk-summary-list govuk-!-margin-bottom-9">
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">
              Need postal copies of letters  
            </dt>
            <dd class="govuk-summary-list__value">
              {{data['paperless']}}
            </dd>
            <dd class="govuk-summary-list__actions" style="vertical-align: top; padding-right: 20px;">
              <a class="govuk-link"href="#">Change<span class="govuk-visually-hidden">name</span></a>
            </dd>
        </div>
        </dl>
        

      <form class="form" action="paperlessConfirmation" method="POST">
      <button type="submit" class="govuk-button">
        Continue
      </button>
	 </form>

	  </div>
	  </div>

{% endblock %}