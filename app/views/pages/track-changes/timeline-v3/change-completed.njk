{% extends "layouts/layout.njk" %}

{% block pageTitle %}
  Track Changes
{% endblock %}

{% block content %}

  <a href="/pages/track-changes/timeline-v2" class="govuk-back-link">Back to Track Changes</a><br></br>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l">
        Change bank details for Claire
      </h1>
      {{govukTag({
                text: "Accepted",
                classes: "govuk-tag--green govuk-!-margin-bottom-3"
            })}}
    <p class="govuk-body">
              We have completed and closed your change report. Your change has been accepted and <a href="/pages/messages" class="govuk-link govuk-!-margin-top-3">we have sent you a confirmation letter</a>.
            </p>
    </div>
  </div>
{% endblock %}