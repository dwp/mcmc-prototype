{% block content %}


  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
	  <h1 class="govuk-heading-xl govuk-!-margin-bottom-4">
        Welcome Sarah
      </h1>
      <h2 class="govuk-heading-l govuk-!-margin-bottom-6">
        You are on Collect and Pay
      </h2>
    </div>

    <div class="govuk-grid-column-full">
        {% set html %}
        <p class="govuk-notification-banner__heading bannerNoMaxWidth">
          We have a request that needs your attention.
          <a href="/pages/caseworker-messaging-mvp/action-required">View requests.</a>
        </p>
        {% endset %}
        {{ 
        govukNotificationBanner({
          html: html
        })
      }}
    </div>

      <div class="govuk-grid-column-full">
      <h2 class="govuk-heading-m govuk-!-margin-bottom-2">What's new</h2>
      <ul class="govuk-list useful-links">
        <li class="inline">
          <p class="govuk-body"><a class="govuk-link" href="./whatsNew">View March 2026 features:</a> Report a change and payment breakdowns.</p>
        </li>
      </ul>
    </div>

    <div class="govuk-grid-column-full">
      <div class="blueDivider"></div>
    </div>

    <div class="govuk-grid-column-full">
    <h2 class="govuk-heading-l govuk-!-margin-bottom-5">Updates</h2>
    </div>



