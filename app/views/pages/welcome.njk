{% extends "layouts/layout.njk" %}

{% block header %}
  {# {% include "includes/header_handover.njk" %} #}
  {% include "includes/header.njk" %}
{% endblock %}

{% block beforeContent %}
  {% if not noAccountMenuOrFooter %}
    {% include "includes/partials/account-menu.njk" %}
