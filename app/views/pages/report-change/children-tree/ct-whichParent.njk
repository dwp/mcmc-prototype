{% extends "layouts/layout.njk" %}

{% block content %}
{{ govukBackLink({
      "text": "Back",
      "href": "javascript: window.history.go(-1)"
    }) 
}}

	<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <h1 class="govuk-heading-xl">Who has the same parents as the child you are reporting? </h1>
      <p class="govuk-hint">We group your children in cases according to their other parent</p>

      <form class="form" action="" method="POST">

        {{ govukRadios({
          idPrefix: "childrentree-whichParent",
          name: "childrentree-whichParent",
          fieldset: {
            legend: {
              text: "",
              isPageHeading: no,
              classes: "govuk-fieldset__legend--l"
            }
          },
          items: [
            {
              value: "Bill1",
              text: "Bill, Bob and 1 other"
            },
            {
              value: "Bill",
              text: "Bill",
               hint: {
                text: "Born 6 September 2017"
              }
            },
            {
              value: "Alex",
              text: "Alex"
            },
              {
              divider: "or"
            },
            {
              value: "None",
              text: "None of these",
              hint: {
                text: "You do not already have a child maintenance case with their parent"
              }
            }
          ]
        }) }}

        <div class="govuk-inset-text">
          Your case with Sophie, Jack and 2 others has now closed. If your new child has the same parents, <a href="#" class="govuk-link">start a new application</a>"
        </div>

      <button type="submit" class="govuk-button">
        Continue
      </button>
	 </form>

	  </div>
	  </div>

{% endblock %}