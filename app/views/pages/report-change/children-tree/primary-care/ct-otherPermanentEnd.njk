{% extends "layouts/layout.njk" %}

{% block content %}
{{ govukBackLink({
      "text": "Back",
      "href": "javascript: window.history.go(-1)"
    }) 
}}

	<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <h1 class="govuk-heading-xl">When do you expect the other parent to become {{data['childrentree-whichChild']}}'s main carer again?</h1>

       <form class="form" action="ct-otherChildBenefit" method="POST">
     {{ govukDateInput({
        id: "other-date-end",
        namePrefix: "other-date-end",
        fieldset: {
          legend: {
            text: "",
            isPageHeading: false,
            classes: "govuk-fieldset__legend--l"
          }
        },
        hint: {
          text: "For example, 27 3 2026"
        }
      }) }}

      <button type="submit" class="govuk-button">
        Continue
      </button>

      <button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button">
        I do not know
      </button>
	 </form>

	  </div>
	  </div>

{% endblock %}