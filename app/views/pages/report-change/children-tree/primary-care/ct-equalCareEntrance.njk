{% extends "layouts/layout.njk" %}

{% block content %}
{{ govukBackLink({
      "text": "Back",
      "href": "javascript: window.history.go(-1)"
    }) 
}}

	<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <h1 class="govuk-heading-xl">The other parent now has most of Bill's day-to-day care</h1>
      <p class="govuk-body">Tell us when this changed:</p>
       <ul class="govuk-list govuk-list--bullet govuk-list--spaced">
        <li>The date must be today or in the past. Only report it on or after the date the change happens</li>
        <li>If you cannot remember the exact date tell us an approximate date</li>
        <li>If you have a written agreement in place, it should tell you the date Bill's other parent started having most of their day-to-day care</li>
        <li>Send you a letter in <a href="#" class="govuk-link">notifications</a> to let you know about any changes and effects on your payments</li>
      </ul>

      <br>

      <form class="form" action="ct-equalOtherChildren" method="POST">

      {{ govukDateInput({
        id: "passport-issued",
        namePrefix: "passport-issued",
        fieldset: {
          legend: {
            text: "When did Bill's day-to-day care change?",
            isPageHeading: true,
            classes: "govuk-fieldset__legend--l"
          }
        },
        hint: {
          text: "For example, 27 3 2026"
        }
      }) }}


      <button type="submit" class="govuk-button">
        Continue
      </button>
	 </form>

	  </div>
	  </div>

{% endblock %}