{% extends "layouts/layout.njk" %}

{% block content %}
{{ govukBackLink({
      "text": "Back",
      "href": "javascript: window.history.go(-1)"
    }) 
}}

	<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <h1 class="govuk-heading-xl">Is this change permanent?</h1>
      <p class="govuk-hint">Brenda plans to have Bill's day-to-day care for the foreseeable future.</p>

       <form class="form" action="ct-otherPermanentEnd" method="POST">
            {{ govukRadios({
          idPrefix: "childrentree-otherPermanent",
          name: "childrentree-otherPermanent",
          fieldset: {
            legend: {
              text: "",
              isPageHeading: no,
              classes: "govuk-fieldset__legend--l"
            }
          },
          items: [
 
            {
              value: "Yes",
              text: "Yes"
            },
                  {
              value: "No",
              text: "No"
            }
          ]
        }) }}

      <button type="submit" class="govuk-button">
        Continue
      </button>
	 </form>

	  </div>
	  </div>

{% endblock %}