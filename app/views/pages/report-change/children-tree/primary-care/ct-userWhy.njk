{% extends "layouts/main.njk" %}

{% block content %}
{{ govukBackLink({
      "text": "Back",
      "href": "javascript: window.history.go(-1)"
    }) 
}}

	<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <h1 class="govuk-heading-xl">Why have you become {{data['childrentree-whichChild']}}'s main day-to-day carer?</h1>

       <form class="form" action="ct-userPermanent" method="POST">
          {{ govukCharacterCount({
            name: "whyCare",
            id: "whyCare",
            maxlength: 200,
            label: {
              text: "",
              classes: "govuk-label--m",
              isPageHeading: true
            },
            hint: {
              text: "Do not include identifying or financial information like your National Insurance number or credit card details"
            }
          }) }}

      <button type="submit" class="govuk-button">
        Continue
      </button>
	 </form>

	  </div>
	  </div>

{% endblock %}