{% extends "layouts/layout.njk" %}

{% block content %}
{{ govukBackLink({
      "text": "Back",
      "href": "javascript: window.history.go(-1)"
    }) 
}}

	<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <h1 class="govuk-heading-xl">When do you expect the other parent to become Bill's main carer again?</h1>

       <form class="form" action="./seven-questions/contact" method="POST">
     {{ govukDateInput({
        id: "childrentree-userPermanentEnd",
        namePrefix: "childrentree-userPermanentEnd",
        fieldset: {
          legend: {
            text: "",
            isPageHeading: false,
            classes: "govuk-fieldset__legend--l"
          }
        },
        hint: {
          text: "For example, 27 3 2026"
        }
      }) }}

      <p class="govuk-body"><a href="#" class="govuk-link">I do not know</a></p>

      <button type="submit" class="govuk-button">
        Continue
      </button>
	 </form>

	  </div>
	  </div>

{% endblock %}