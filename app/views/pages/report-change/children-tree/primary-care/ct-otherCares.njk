{% extends "layouts/main.njk" %}

{% block content %}
{{ govukBackLink({
      "text": "Back",
      "href": "javascript: window.history.go(-1)"
    }) 
}}

	<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <h1 class="govuk-heading-xl">What is {{data['other-firstName']}}'s relationship to {{data['childrentree-whichChild']}} </h1>
      
 
      <form class="form" action="ct-otherDayToDayDate" method="POST">

    {% set textHtml %}
    {{ govukInput({
      id: "otherRelationship-ft",
      name: "otherRelationship-ft",
      type: "tel",
      autocomplete: "tel",
      classes: "govuk-!-width-one-third",
      label: {
        text: "What is their relationship"
      }
    }) }}
    {% endset -%}

    {{ govukRadios({
      name: "otherRelationship",
      id: "otherRelationship",
      fieldset: {
        legend: {
          text: "",
          isPageHeading: false,
          classes: "govuk-fieldset__legend--l"
        }
      },
      hint: {
        text: "Select one option"
      },
      items: [
        {
          value: "Grandparent",
          text: "Grandparent"
        },
        {
          value: "Auntie",
          text: "Auntie"
        },
        {
          value: "Uncle",
          text: "Uncle"
        },
        {
          value: "Another relationship",
          text: "Another relationship",
          conditional: {
            html: textHtml
          }
        }
      ]
    }) }}

    <p class="govuk-body"><a href="#" class="govuk-link">I do not know</a></p>

      <button type="submit" class="govuk-button">
        Continue
      </button>
	 </form>

	  </div>
	  </div>

{% endblock %}