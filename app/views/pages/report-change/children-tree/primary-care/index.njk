{% extends "layouts/layout.njk" %}

{% block content %}
{{ govukBackLink({
      "text": "Back",
      "href": "javascript: window.history.go(-1)"
    }) 
}}

	<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <h1 class="govuk-heading-xl">What has changed?</h1>
      
      <form class="form" action="" method="POST">
         {{ govukRadios({
          idPrefix: "childrentree-primaryOrEqual",
          name: "childrentree-primaryOrEqual",
          fieldset: {
            legend: {
              text: "",
              isPageHeading: no,
              classes: "govuk-fieldset__legend--l"
            }
          },
          items: [
 
            {
              value: "equal",
              text: "How often Bill stays overnight with you",
              hint: {
                text: "This is known as shared care"
              }
            },
                  {
              value: "primary",
              text: "The other parent no longer has most of Bill's day-to-day care",
              hint: {
                text: "This is known as primary care"
              }
            },
             {
              value: "adoption",
              text: "Bill has been adopted"
            },
             {
              value: "fte",
              text: "Bill has left full time education"

            }
          ]
        }) }}

      <button type="submit" class="govuk-button">
        Continue
      </button>
	 </form>

	  </div>
	  </div>

{% endblock %}