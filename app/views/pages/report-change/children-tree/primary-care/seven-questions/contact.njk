{% extends "layouts/main.njk" %}

{% block content %}
{{ govukBackLink({
      "text": "Back",
      "href": "javascript: window.history.go(-1)"
    }) 
}}

	<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

        <h1 class="govuk-heading-xl">
        Emergency contact
      </h1>

      <h2 class="govuk-caption-l">
        Since {{data['careDate-day'] + ' ' + data['careDate-month'] + ' ' + data['careDate-year']}}, how often have you
      <h2 class="govuk-heading-l">
        been {{data['childrentree-whichChild']}}'s emergency contact?
      </h2>


    

      <form class="form" method="POST" action="dayTime">
      
             {# {% set OtherArrangementMeals %}
            {{ govukCharacterCount({
        name: "costMeals",
        id: "costMeals",
        maxlength: 200,
        label: {
            text: "",
            classes: "govuk-label--l",
            isPageHeading: false
        },
        hint: {
            text: "For example, for school or a childminder"
        }
        }) }}
      {% endset -%} #}
       <p class="govuk-body">
       For example, for school or a childminder 
      </p>

      {{ govukRadios({
        name: "ct-contact",
        items: [
          {
            value: "Most",
            text: "More than half the time"

          },
          {
            value: "Half",
            text: "Half of the time"

          },
          {
            value: "Less",
            text: "Less than half the time"

          }
        ]
      }) }}


      <h2 class="govuk-heading-l">
        Do you need to explain in more detail?
      </h2>

        <p class="govuk-body">
       For example, because one parent works from home so is more available to take calls
      </p>

       {% set OtherArrangement %}
            {{ govukCharacterCount({
        name: "ct-contact-ft",
        id: "ct-contact-ft",
        maxlength: 200,
        label: {
            text: "",
            classes: "govuk-label--l",
            isPageHeading: false
        },
        hint: {
            text: "Explain in more detail"
        }
        }) }}
      {% endset -%}

      {{ govukRadios({
        name: "howOften",
        items: [
          {
            value: "No",
            text: "No"
          },
          {
            value: "Yes",
            text: "Yes",
            conditional: {
              html: OtherArrangement
            }
          }
        ]
      }) }}

      <button type="submit" class="govuk-button">
        Continue
      </button>

	 </form>

	  </div>
	  </div>

{% endblock %}