{% extends "layouts/main.njk" %}

{% block content %}
{{ govukBackLink({
      "text": "Back",
      "href": "javascript: window.history.go(-1)"
    }) 
}}

{% if (data['careDate-month'] === "1" or data['careDate-month'] === "01" ) %} 
{% set month = "Jan" %}
{% elif (data['careDate-month'] === "2" or data['careDate-month'] === "02"  ) %} 
{% set month = "Feb" %}
{% elif (data['careDate-month'] === "3" or data['careDate-month'] === "03" ) %} 
{% set month = "Mar" %}
{% elif (data['careDate-month'] === "4" or data['careDate-month'] === "04") %} 
{% set month = "Apr" %}
{% elif (data['careDate-month'] === "5" or data['careDate-month'] === "05") %} 
{% set month = "May" %}
{% elif (data['careDate-month'] === "6" or data['careDate-month'] === "06") %} 
{% set month = "Jun" %}
{% elif (data['careDate-month'] === "7" or data['careDate-month'] === "07" ) %} 
{% set month = "Jul" %}
{% elif (data['careDate-month'] === "8" or data['careDate-month'] === "08" ) %} 
{% set month = "Aug" %}
{% elif (data['careDate-month'] === "9" or data['careDate-month'] === "09" ) %} 
{% set month = "Sep" %}
{% elif (data['careDate-month'] === "10" or data['careDate-month'] === "010" ) %} 
{% set month = "Oct" %}
{% elif (data['careDate-month'] === "11" or data['careDate-month'] === "011" ) %} 
{% set month = "Nov" %}
{% elif (data['careDate-month'] === "12" or data['careDate-month'] === "012") %} 
{% set month = "Dec" %}
{% else %}
{% set month = "Month" %}
{% endif %}

	<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

        <h1 class="govuk-heading-xl">
        Childcare
      </h1>

       {% if (month === "May" or month === "Apr" ) %} 
      <h2 class="govuk-heading-l">
       How often do you expect to arrange {{data['childrentree-whichChild']}}'s childcare?
      </h2>
      {% else %}
        <h2 class="govuk-caption-l">
        Since {{data['careDate-day'] + ' '}} {{ month }} {{' ' + data['careDate-year']}}
      <h2 class="govuk-heading-l">
        How often have you arranged {{data['childrentree-whichChild']}}'s childcare?
      </h2>
      {% endif %}

      


      <form class="form" method="POST" action="items">
 

          <p class="govuk-body">
       For example, a childminder or after-school club that has to be paid for
      </p>
  
      {{ govukRadios({
        name: "ct-childcare",
        items: [
          {
            value: "More than half the time",
            text: "More than half the time"

          },
          {
            value: "Half the time",
            text: "Half the time"

          },
          {
            value: "Less than half the time",
            text: "Less than half the time"

          }

        ]
      }) }}

       {% if (month === "May" or month === "Apr" ) %} 
      <h2 class="govuk-heading-l">
       How often do you expect to pay for {{data['childrentree-whichChild']}}'s childcare?
      </h2>
      {% else %}
        <h2 class="govuk-caption-l">
        Since {{data['careDate-day'] + ' '}} {{ month }} {{' ' + data['careDate-year']}}
      <h2 class="govuk-heading-l">
        How often have you paid for {{data['childrentree-whichChild']}}'s childcare?
      </h2>
      {% endif %}


      <form class="form" method="POST" action="items">
      
  
      {{ govukRadios({
        name: "ct-childcare-paid",
        items: [
            {
            value: "More than half the time",
            text: "More than half the time"

          },
          {
            value: "Half the time",
            text: "Half the time"

          },
          {
            value: "Less than half the time",
            text: "Less than half the time"

          }
        ]
      }) }}



      <h2 class="govuk-heading-l">
        Do you need to explain in more detail?
      </h2>

        <p class="govuk-body">
       For example, if one parent gets a tax-free childcare voucher
      </p>

       {% set OtherArrangement %}
            {{ govukCharacterCount({
        name: "ct-childcare-ft",
        id: "ct-childcare-ft",
        maxlength: 200,
        label: {
            text: "",
            classes: "govuk-label--l",
            isPageHeading: false
        },
        hint: {
            text: "Explain in more detail"
        }
        }) }}
      {% endset -%}

      {{ govukRadios({
        name: "howOften",
        items: [
          {
            value: "No",
            text: "No"
          },
          {
            value: "Yes",
            text: "Yes",
            conditional: {
              html: OtherArrangement
            }
          }
        ]
      }) }}

      <button type="submit" class="govuk-button">
        Continue
      </button>

	 </form>

	  </div>
	  </div>

{% endblock %}