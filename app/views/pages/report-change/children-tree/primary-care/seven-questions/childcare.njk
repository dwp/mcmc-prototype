{% extends "layouts/main.njk" %}

{% block content %}
{{ govukBackLink({
      "text": "Back",
      "href": "javascript: window.history.go(-1)"
    }) 
}}

	<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

        <h1 class="govuk-heading-xl">
        Childcare
      </h1>

      <h2 class="govuk-caption-l">
        Since {{data['careDate-day'] + ' ' + data['careDate-month'] + ' ' + data['careDate-year']}}, how often have you
      <h2 class="govuk-heading-l">
        arranged {{data['childrentree-whichChild']}}'s childcare?
      </h2>


      <form class="form" method="POST" action="items">
 

          <p class="govuk-body">
       For example, a childminder or after-school club that has to be paid for
      </p>
  
      {{ govukRadios({
        name: "ct-childcare",
        items: [
          {
            value: "Always",
            text: "Always"
          },
          {
            value: "Most",
            text: "Most of the time"

          },
          {
            value: "Half",
            text: "Half of the time"

          },
          {
            value: "Less",
            text: "Less than half of the time"

          },
  
          {
            value: "Never",
            text: "Never"
          },
           {
            divider: "or"
            },
          {
            value: "Not needed childcare",
            text: "Bill has not needed paid childcare since" + ' ' + data['careDate-day'] + ' ' + data['careDate-month'] + ' ' + data['careDate-year']
          }

        ]
      }) }}

            <h2 class="govuk-caption-l">
        Since {{data['careDate-day'] + ' ' + data['careDate-month'] + ' ' + data['careDate-year']}}, how often have you
      <h2 class="govuk-heading-l">
        paid for {{data['childrentree-whichChild']}}'s childcare?
      </h2>


      <form class="form" method="POST" action="items">
      
          <p class="govuk-body">
       For example, a childminder or after-school club that has to be paid for
      </p>
  
      {{ govukRadios({
        name: "ct-childcare-paid",
        items: [
          {
            value: "Always",
            text: "Always"
          },
          {
            value: "Most",
            text: "Most of the time"

          },
          {
            value: "Half",
            text: "Half of the time"

          },
          {
            value: "Less",
            text: "Less than half of the time"

          },
          {
            value: "Never",
            text: "Never"
          }
        ]
      }) }}



      <h2 class="govuk-heading-l">
        Do you need to explain in more detail?
      </h2>

        <p class="govuk-body">
       For example, because one parent works shifts so is unable to have them at home
      </p>

       {% set OtherArrangement %}
            {{ govukCharacterCount({
        name: "ct-childcare-ft",
        id: "ct-childcare-ft",
        maxlength: 200,
        label: {
            text: "",
            classes: "govuk-label--l",
            isPageHeading: false
        },
        hint: {
            text: "Explain in more detail"
        }
        }) }}
      {% endset -%}

      {{ govukRadios({
        name: "howOften",
        items: [
          {
            value: "No",
            text: "No"
          },
          {
            value: "Yes",
            text: "Yes",
            conditional: {
              html: OtherArrangement
            }
          }
        ]
      }) }}

      <button type="submit" class="govuk-button">
        Continue
      </button>

	 </form>

	  </div>
	  </div>

{% endblock %}