{% extends "layouts/layout.njk" %}

{% block content %}
{{ govukBackLink({
      "text": "Back",
      "href": "javascript: window.history.go(-1)"
    }) 
}}

	<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <h1 class="govuk-heading-xl">Declaration</h1>
      <p class="govuk-body">Before submitting you agree that:</p>
      <ul class="govuk-list govuk-list--bullet">
          <li>the information is correct and complete as far as you know</li>
          <li>you will tell us if anything else changes that might affect your child maintenance payments</li>
      </ul>
    
      <p class="govuk-body">If you deliberately give us wrong or incomplete information, or you do not report changes, you may:</p>
      <ul class="govuk-list govuk-list--bullet">
          <li>be prosecuted</li>
          <li>need to pay a financial penalty</li>
      </ul>

      <form class="form" action="ct-otherConfirmation" method="POST">

      <button type="submit" class="govuk-button">
        I agree - submit
      </button>
	 </form>

	  </div>
	  </div>

{% endblock %}