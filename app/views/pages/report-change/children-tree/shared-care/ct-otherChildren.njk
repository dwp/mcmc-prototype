{% extends "layouts/layout.njk" %}

{% block content %}
{{ govukBackLink({
      "text": "Back",
      "href": "javascript: window.history.go(-1)"
    }) 
}}

	<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <h1 class="govuk-heading-l">Other children with the same change to overnight shared care</h1>
        
      <p class="govuk-body">We work out your payments by looking at each child's shared care arrangement individually. If we approve the change for other children, there may be further changes to how much you need to pay.</p>


      <form class="form" action="ct-outcomeBandOver175" method="POST">
      {{ govukCheckboxes({
        name: "otherChildrenWho",
        fieldset: {
          legend: {
            text: "Which children does this also apply to?",
            isPageHeading: true,
            classes: "govuk-fieldset__legend--l"
          }
        },
        hint: {
          text: "Select all that apply"
        },
        items: [
          {
            value: "Bob",
            text: "Bob"
          },
          {
            value: "Ben",
            text: "Ben"
          },
          {
            value: "none",
            text: "None of the above"
          }
        ]
      }) }}
                

      <button type="submit" class="govuk-button">
        Continue
      </button>
	 </form>

	  </div>
	  </div>

{% endblock %}