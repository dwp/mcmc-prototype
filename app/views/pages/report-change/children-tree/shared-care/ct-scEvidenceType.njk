{% extends "layouts/layout.njk" %}

{% block content %}
{{ govukBackLink({
      "text": "Back",
      "href": "javascript: window.history.go(-1)"
    }) 
}}

	<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <h1 class="govuk-heading-xl">Which type of evidence do you have</h1>
      <p class="govuk-body">Choose only the most recent one. We will ask you to upload the document later.</p>
  

      <form class="form" action="ct-overnightStays" method="POST">


        {{ govukRadios({
          idPrefix: "childrentree-whatToReport",
          name: "childrentree-whatToReport",
          fieldset: {
            legend: {
              text: "Do you have one of these types of evidence",
              isPageHeading: yes,
              classes: "govuk-fieldset__legend--l"
            }
          },
          items: [
 
            {
              value: "CourtOrder",
              text: "A current court order"
            },
            {
              value: "FormalAgreement",
              text: "A formal agreement, for example drawn by a solicitor"
            },
            {
              value: "CAFCASS",
              text: "Another official document",
              hint: { 
              text: "for example reports from Chuldren and Family Court Advisory and support service (CAFCASS) or social services"
              }
            },
            {
              divider: "or"
            },
            {
              value: "None",
              text: "None of these"
            }
          ]
        }) }}

      <button type="submit" class="govuk-button">
        Continue
      </button>
	 </form>

	  </div>
	  </div>

{% endblock %}