{% extends "layouts/layout.njk" %}

{% block content %}
{{ govukBackLink({
      "text": "Back",
      "href": "javascript: window.history.go(-1)"
    }) 
}}

	<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <h1 class="govuk-heading-xl">
        How often does Bill stay overnight with a foster carer or in a care home?
      </h1>
      <p class="govuk-body">This is known as a local authority care.</p>

      <form class="form" method="POST" action="ct-scEvidenceType">
       
          {% set WeeklyHTML %}
       {{ govukInput({
        id: "howManyAWeekFoster",
        name: "howManyAWeekFoster",
        type: "number",
        autocomplete: "number",
        spellcheck: false,
        classes: "govuk-!-width-one-third",
        label: {
          text: "How many overnight stays in a week?"
        }
      }) }}
      {% endset -%}

      {% set FortnightlyHTML %}
      {{ govukInput({
        id: "howManyAFortnightFoster",
        name: "howManyAFortnightFoster",
        type: "number",
        autocomplete: "number",
        classes: "govuk-!-width-one-third",
        label: {
          text: "How many overnight stays in a fortnight?"
        }
      }) }}
      {% endset -%}

      {% set MonthlyHTML %}
      {{ govukInput({
        id: "howManyAMonthFoster",
        name: "howManyAMonthFoster",
        type: "number",
        autocomplete: "number",
        classes: "govuk-!-width-one-third",
        label: {
          text: "How many overnight stays in a month?"
        }
      }) }}
      {% endset -%}

      {% set OtherHTML %}
      {{ govukInput({
        id: "howManyAYearFoster",
        name: "howManyAYearFoster",
        type: "tel",
        autocomplete: "tel",
        classes: "govuk-!-width-one-third",
        label: {
          text: "How many overnight stays in a year"
        }
      }) }}
      {% endset -%}

      {{ govukRadios({
        name: "howOftenFoster",
        items: [
          {
            value: "Never",
            text: "Never"
          },
          {
            value: "Weekly",
            text: "Weekly",
            conditional: {
              html: WeeklyHTML
            }
          },
          {
            value: "Fortnightly",
            text: "Fortnightly",
            conditional: {
              html: FortnightlyHTML
            }
          },
          {
            value: "Monthly",
            text: "Monthly",
            conditional: {
              html: MonthlyHTML
            }
          },
          {
            value: "Other",
            text: "Other",
            conditional: {
              html: OtherHTML
            }
          }
        ]
      }) }}

      <button type="submit" class="govuk-button">
        Continue
      </button>

	 </form>

	  </div>
	  </div>

{% endblock %}